# ========================================
#OBLIGATORIO - SIN ESTO NO FUNCIONA
# ========================================
# Google Gemini API Key (REQUERIDA)
# Obtén tu API key GRATUITA en: https://ai.google.dev/
# 1. Ve a https://ai.google.dev/
# 2. Haz clic en "Get API Key"
# 3. Copia tu API key y pégala abajo
GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# ========================================
#OPCIONAL - Base de Datos en la Nube
# ========================================
# Por defecto la app usa SQLite local (no necesita configuración)
# Solo completa esto si quieres usar Supabase PostgreSQL en la nube
# Deja en blanco para usar SQLite local automáticamente
# Al usar SQLite, los datos se guardan en un archivo local llamado "local_database.db" en la carpeta del proyecto

SUPABASE_HOST=tu_host.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=tu_password_aqui

# ========================================
#OPCIONAL - Verificación por Email
# ========================================
# Por defecto los códigos se imprimen en la consola
# Solo completa esto si quieres enviar códigos por email
# Usa "Contraseña de Aplicación" de Gmail (no tu contraseña real)
# 
# Pasos para generar app password:
# 1. Ve a https://myaccount.google.com/apppasswords
# 2. Selecciona "Mail" y tu dispositivo
# 3. Se generará una contraseña de 16 caracteres
# 4. Copia sin espacios en EMAIL_PASSWORD

# en email_user pon tu email completo o el alias que hayas configurado para enviar emails
EMAIL_USER=
#en email_password pon la contraseña de aplicación generada (16 caracteres sin espacios)
EMAIL_PASSWORD=

#En caso de que no quieras configurar esto, el codigo de confirmacion se imprimirá en la consola para que puedas copiarlo manualmente.